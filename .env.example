# LLM provider: "anthropic" or "ollama"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Ollama (if LLM_PROVIDER=ollama)
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_SUMMARIZER_MODEL=qwen2.5:7b

# Postgres
POSTGRES_PASSWORD=chat_app_passw0rd

# Keycloak (local dev — in-memory DB, not for production)
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
KEYCLOAK_INTERNAL_URL=http://localhost:8080
KEYCLOAK_REALM=multi-tool-chat
KEYCLOAK_CLIENT_ID=frontend

# Vite frontend
VITE_KEYCLOAK_EXTERNAL_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=multi-tool-chat
VITE_KEYCLOAK_CLIENT_ID=frontend
